generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum OrderStatus {
  PENDING
  SUCCESS
  FAILED
}

enum DepositStatus {
  PENDING
  CONFIRMED
  EXPIRED
  REJECTED
}

enum TransactionType {
  ORDER
  DEPOSIT
  ADJUSTMENT
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

enum FieldType {
  TEXT
  NUMBER
  SELECT
}

model User {
  id                    String          @id @default(uuid())
  fullName              String
  username              String          @unique
  whatsapp              String
  email                 String          @unique
  passwordHash          String
  pinHash               String?
  pinSetAt              DateTime?
  balance               Decimal         @db.Decimal(18, 2) @default(0)
  role                  UserRole        @default(USER)
  status                UserStatus      @default(ACTIVE)
  deletedAt             DateTime?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  refreshTokens         RefreshToken[]
  orders                Order[]
  deposits              Deposit[]
  transactions          Transaction[]
  notifications         Notification[]
  balanceAdjustments    BalanceAdjustment[] @relation("AdjustedUser")
  madeBalanceAdjustments BalanceAdjustment[] @relation("AdjustedBy")
}

model RefreshToken {
  id          String    @id @default(uuid())
  userId      String
  tokenHash   String
  expiresAt   DateTime
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Category {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  imageUrl    String?
  sortOrder   Int       @default(0)
  status      Boolean   @default(true)
  badge       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  services    Service[]
}

model Service {
  id          String              @id @default(uuid())
  categoryId  String
  name        String
  slug        String
  logoUrl     String?
  description String?
  status      Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  category      Category          @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  inputFields   ServiceInputField[]
  products      Product[]
  orders        Order[]

  @@unique([categoryId, slug])
  @@index([categoryId])
}

model ServiceInputField {
  id           String    @id @default(uuid())
  serviceId    String
  label        String
  key          String
  type         FieldType
  required     Boolean   @default(true)
  placeholder  String?
  optionsJson  Json?
  sortOrder    Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId])
}

model Product {
  id           String    @id @default(uuid())
  serviceId    String
  name         String
  slug         String
  tabType      String?
  nominal      Decimal   @db.Decimal(18, 2)
  sellingPrice Decimal   @db.Decimal(18, 2)
  status       Boolean   @default(true)
  stock        Int?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  orders  Order[]

  @@unique([serviceId, slug])
  @@index([serviceId])
}

model Order {
  id            String      @id @default(uuid())
  userId        String
  serviceId     String
  productId     String
  customerData  Json
  price         Decimal     @db.Decimal(18, 2)
  fee           Decimal     @db.Decimal(18, 2) @default(0)
  total         Decimal     @db.Decimal(18, 2)
  status        OrderStatus @default(PENDING)
  deletedAt     DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  user      User      @relation(fields: [userId], references: [id])
  service   Service   @relation(fields: [serviceId], references: [id])
  product   Product   @relation(fields: [productId], references: [id])
  transaction Transaction?

  @@index([userId])
  @@index([serviceId])
  @@index([productId])
  @@index([status])
}

model PaymentMethod {
  id             String    @id @default(uuid())
  name           String
  accountNumber  String
  accountName    String
  logoUrl        String?
  uniqueCodeEnabled Boolean @default(false)
  minDeposit     Decimal   @db.Decimal(18, 2)
  maxDeposit     Decimal   @db.Decimal(18, 2)
  expiryMinutes  Int       @default(30)
  status         Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  deposits Deposit[]
}

model Deposit {
  id             String        @id @default(uuid())
  userId         String
  paymentMethodId String
  amount         Decimal       @db.Decimal(18, 2)
  uniqueCode     Int?          @default(0)
  transferAmount Decimal       @db.Decimal(18, 2)
  proofImageUrl  String?
  expiredAt      DateTime?
  status         DepositStatus @default(PENDING)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  user          User          @relation(fields: [userId], references: [id])
  paymentMethod PaymentMethod @relation(fields: [paymentMethodId], references: [id])
  transaction   Transaction?

  @@index([userId])
  @@index([paymentMethodId])
  @@index([status])
}

model Transaction {
  id          String            @id @default(uuid())
  userId      String
  type        TransactionType
  status      TransactionStatus @default(PENDING)
  amount      Decimal           @db.Decimal(18, 2)
  description String?
  orderId     String?           @unique
  depositId   String?           @unique
  metadata    Json?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  user    User     @relation(fields: [userId], references: [id])
  order   Order?   @relation(fields: [orderId], references: [id])
  deposit Deposit? @relation(fields: [depositId], references: [id])

  @@index([userId])
  @@index([type])
  @@index([status])
}

model BalanceAdjustment {
  id           String   @id @default(uuid())
  userId       String
  adjustedById String
  amount       Decimal  @db.Decimal(18, 2)
  note         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user       User @relation("AdjustedUser", fields: [userId], references: [id])
  adjustedBy User @relation("AdjustedBy", fields: [adjustedById], references: [id])

  @@index([userId])
  @@index([adjustedById])
}

model Notification {
  id         String   @id @default(uuid())
  userId     String
  title      String
  message    String
  readAt     DateTime?
  metadata   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([readAt])
}

model AppSetting {
  id         String   @id @default(uuid())
  key        String   @unique
  value      String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}